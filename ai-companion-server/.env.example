# AI Companion Robot Server Configuration
# Copy this file to .env and fill in your credentials

# ======================
# Server Configuration
# ======================
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_PRETTY=true

# ======================
# AI Service Provider
# ======================
# Options: tencent | volcengine | xunfei | debug
# 优先 Tencent, 其次 Volcano Engine (火山引擎/字节跳动)
AI_PROVIDER=tencent

# ======================
# Tencent Cloud (优先ASR/TTS)
# ======================
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_REGION=ap-guangzhou
TENCENT_APP_ID=your_app_id

# ======================
# 火山引擎 Volcengine (字节跳动) - 备选
# ======================
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_APP_ID=your_app_id

# ======================
# 讯飞语音 - 备选
# ======================
XUNFEI_APP_ID=your_xunfei_app_id
XUNFEI_API_KEY=your_xunfei_api_key
XUNFEI_API_SECRET=your_xunfei_api_secret

# ======================
# LLM - 对话模型 (优先 Kimi)
# ======================
# Options: kimi | openai | debug
LLM_PROVIDER=kimi

# Kimi (Moonshot AI)
KIMI_API_KEY=your_kimi_api_key

# OpenAI - 备选
OPENAI_API_KEY=your_openai_api_key

# ======================
# Redis (可选)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ======================
# AI Companion System Prompt
# ======================
SYSTEM_PROMPT=你是一个温暖友好的AI陪伴机器人。你可以：进行自然的对话交流，理解和回应用户的情感需求，提供陪伴和情绪价值，保持简洁友好的回复风格。请用简短自然的语言回复，每次回复控制在100字以内。